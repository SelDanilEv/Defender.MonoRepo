{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "IncludeScopes": true,
      "LogLevel": {
        "Default": "Information",
        "System": "Information",
        "Microsoft": "Information"
      }
    }
  },
  "JwtTokenIssuer": "Defender",
  "JwtTokenAudience": "defender-api",

  "PortalOAuth": {
    "Issuer": "https://portal.coded-by-danil.dev",
    "McpResourceUri": "https://mcp.coded-by-danil.dev/mcp",
    "McpAudience": "defender-mcp",
    "BffAudience": "defender-api",
    "SigningKeySecretName": "PortalOAuthSigningKey",
    "EncryptionKeySecretName": "PortalOAuthEncryptionKey",
    "AllowedClientOrigins": [
      "https://mcp.coded-by-danil.dev"
    ]
  },

  "DistributedCacheOptions": {
    "DefaultTtl": "1.06:00:00"
  },

  "AllowedHosts": "*"
}
