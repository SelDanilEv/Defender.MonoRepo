  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "avg(up{job=~\"defender-.*\"}) * 100", "refId": "A" }],
      "title": "Service Availability",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "sum(rate(http_requests_received_total[5m])) or vector(0)", "refId": "A" }],
      "title": "Total RPS",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "((sum(rate(http_requests_received_total{code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_received_total[5m])), 0.001)) * 100) or vector(0)", "refId": "A" }],
      "title": "5xx %",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) or vector(0)", "refId": "A" }],
      "title": "Latency p95",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 9,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"defender.*\"}[1h]))", "refId": "A" }],
      "title": "Pod Restarts (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "editorMode": "code", "expr": "sum(kube_pod_container_status_last_terminated_reason{namespace=~\"defender.*\",reason=\"OOMKilled\"})", "refId": "A" }],
      "title": "OOMKilled Containers",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [{ "editorMode": "code", "expr": "sum by (service) (rate(http_requests_received_total{service!=\"\"}[5m])) or on() vector(0)", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (service) (rate(process_cpu_seconds_total{service!=\"\"}[5m]))", "legendFormat": "{{service}} cpu", "refId": "A" },
        { "editorMode": "code", "expr": "sum by (service) (process_working_set_bytes{service!=\"\"}) / 1024 / 1024", "legendFormat": "{{service}} memory (MiB)", "refId": "B" }
      ],
      "title": "CPU and Memory Pressure by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (pod) (rate(container_cpu_cfs_throttled_periods_total{namespace=~\"defender.*\",container!=\"\",image!=\"\"}[5m])) / clamp_min(sum by (pod) (rate(container_cpu_cfs_periods_total{namespace=~\"defender.*\",container!=\"\",image!=\"\"}[5m])), 0.0001)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "CPU Throttling by Pod",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "P000000001" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (pod) (rate(container_memory_working_set_bytes{namespace=~\"defender.*\",container!=\"\",image!=\"\"}[5m])) / 1024 / 1024", "legendFormat": "{{pod}}", "refId": "A" }
      ],
      "title": "Memory Working Set by Pod (MiB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "L000000001" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 20 },
      "id": 7,
      "options": { "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "editorMode": "code", "expr": "{namespace=~\"defender.*\",pod=~\"(identity|user-management|notification|job-scheduler|wallet|risk-games|budget-tracker|personal-food-advisor|portal).*\"} |~ \"(?i)(error|exception|fail)\"", "queryType": "range", "refId": "A" }],
      "title": "Error Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "L000000001" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 20 },
      "id": 8,
      "options": { "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "editorMode": "code", "expr": "{namespace=~\"defender.*\",pod=~\"(identity|user-management|notification|job-scheduler|wallet|risk-games|budget-tracker|personal-food-advisor|portal).*\"}", "queryType": "range", "refId": "A" }],
      "title": "Service Logs",
      "type": "logs"
    }
